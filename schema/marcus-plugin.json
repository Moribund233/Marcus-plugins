{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "Marcus Plugin Manifest",
  "type": "object",
  "required": ["id", "display_name", "version", "api_version", "contribution"],
  "properties": {
    "api_version": {
      "type": "string",
      "description": "Manifest schema version",
      "enum": ["1"]
    },
    "id": {
      "type": "string",
      "description": "Unique plugin identifier (kebab-case)",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable name"
    },
    "description": {
      "type": "string",
      "description": "Short description"
    },
    "icon": {
      "type": "string",
      "description": "Icon file path within the package"
    },
    "categories": {
      "type": "array",
      "items": { "type": "string" }
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+"
    },
    "min_marcus_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "Minimum Marcus version required"
    },
    "contribution": {
      "type": "string",
      "enum": ["web", "terminal", "file"]
    },
    "web": {
      "type": "object",
      "properties": {
        "start_command": { "type": "string" },
        "port": { "type": "integer" },
        "health_check": { "type": "string" },
        "auto_open": { "type": "boolean" }
      }
    },
    "terminal": {
      "type": "object",
      "properties": {
        "command": { "type": "string" },
        "args": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "type": { "type": "string", "enum": ["string", "number", "directory", "file"] },
              "default": {}
            }
          }
        }
      }
    },
    "file": {
      "type": "object",
      "properties": {
        "command": { "type": "string" },
        "input_type": { "type": "string", "enum": ["file", "files", "directory"] },
        "input_extensions": { "type": "array", "items": { "type": "string" } },
        "output_type": { "type": "string", "enum": ["file", "directory"] },
        "args": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "type": { "type": "string", "enum": ["string", "number", "directory", "file"] },
              "default": {}
            }
          }
        }
      }
    },
    "ui": {
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["form", "none"] },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "type": { "type": "string", "enum": ["text", "number", "select", "file", "directory"] },
              "default": {},
              "options": { "type": "array", "items": { "type": "string" } },
              "required": { "type": "boolean" },
              "placeholder": { "type": "string" }
            }
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "style": { "type": "string", "enum": ["primary", "default", "destructive"] }
            }
          }
        },
        "output": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "label": { "type": "string" },
              "type": { "type": "string", "enum": ["text", "image", "file", "table"] }
            }
          }
        }
      }
    }
  }
}
